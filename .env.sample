# ----------------------------------------------------------------------------
# Django
# ----------------------------------------------------------------------------
DJANGO_ENV=local                       # local | production
SECRET_KEY=                            # production'da MAJBURIY (uzun, tasodifiy)
ALLOWED_HOSTS=library.xiuedu.uz,www.library.xiuedu.uz   # faqat production

# ----------------------------------------------------------------------------
# Ma'lumotlar bazasi (faqat production — local SQLite ishlatadi)
# ----------------------------------------------------------------------------
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# ----------------------------------------------------------------------------
# HEMIS oAuth2 — Talaba (Student)
# ----------------------------------------------------------------------------
CLIENT_ID=                             # hemis client id :int
CLIENT_SECRET=                         # hemis client maxfiy kodi :str
REDIRECT_URI=                          # callback manzili :str
AUTHORIZE_URL=https://{university_hemis_url}/oauth/authorize
ACCESS_TOKEN_URL=https://{university_hemis_url}/oauth/access-token
RESOURCE_OWNER_URL=https://{university_hemis_url}/oauth/api/user?fields=id,uuid,employee_id_number,type,roles,name,login,email,picture,firstname,surname,patronymic,birth_date,university_id,phone

# ----------------------------------------------------------------------------
# HEMIS oAuth2 — Xodim (Employee)
# ----------------------------------------------------------------------------
EMPLOYE_AUTHORIZE_URL=https://{university_hemis_url}/oauth/authorize
EMPLOYE_ACCESS_TOKEN_URL=https://{university_hemis_url}/oauth/access-token
EMPLOYE_RESOURCE_OWNER_URL=https://{university_hemis_url}/oauth/api/user
